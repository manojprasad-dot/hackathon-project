{
  "manifest_version": 3,
  "name": "PhishGuard 4.0 — On-Device AI Phishing Detector",
  "version": "4.0.0",
  "description": "AI-powered phishing detection running 100% on-device via ONNX Runtime Web. No server required. Works offline. 30 URL features + 28 email features. Zero data ever leaves your browser.",

  "permissions": [
    "tabs",
    "activeTab",
    "storage",
    "notifications",
    "webNavigation",
    "scripting"
  ],
  "host_permissions": ["<all_urls>"],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://mail.google.com/*",
        "https://outlook.live.com/*",
        "https://outlook.office.com/*",
        "https://outlook.office365.com/*"
      ],
      "js": ["gmail_scanner.js"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "PhishGuard — On-Device AI"
  },

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },

  "web_accessible_resources": [
    {
      "resources": [
        "email_scanner.html",
        "email_scanner.js",
        "report.html",
        "weekly_report.html",
        "warning.html",
        "warning.js",
        "ai/model.onnx",
        "ai/email_model.onnx",
        "ai/ort.min.js",
        "ai/preprocessing.js",
        "ai/email_preprocessor.js",
        "ai/predictor.js"
      ],
      "matches": ["<all_urls>"]
    }
  ],

  "commands": {
    "quick-scan": {
      "suggested_key": {
        "default": "Ctrl+Shift+P",
        "mac":     "Command+Shift+P"
      },
      "description": "Quick scan current page (on-device ONNX inference)"
    }
  }
}
